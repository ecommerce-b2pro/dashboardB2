PORT=3000
JWT_SECRET=troque_este_segredo_em_producao
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=admin@hubvendas.com
ADMIN_PASSWORD=TroqueEstaSenhaAgora123!

# URL de conexão com o PostgreSQL
# Desenvolvimento local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dashboard
# Produção (Railway, Render, Heroku, etc.):
# DATABASE_URL=postgresql://usuario:senha@host:5432/nomebanco

# SSL para PostgreSQL em produção (padrão: false = rejectUnauthorized desabilitado)
# Defina como "true" apenas se o servidor PostgreSQL tiver certificado SSL válido
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
